---
import BaseLayout from "../layouts/BaseLayout.astro";
import Logo from "../components/Logo.astro";
---

<BaseLayout title="404 — troniti">
  <section class="flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <Logo size="lg" class="mb-12" />
    <h1 class="mono text-6xl font-bold text-accent sm:text-8xl">404</h1>
    <p class="mt-4 text-lg text-text-muted">Page not found</p>
    <a
      href="/"
      class="mt-8 rounded-lg bg-accent px-6 py-3 font-medium text-white transition-colors hover:bg-accent-hover"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
