---
---

<section id="waitlist" class="border-t border-border px-6 py-24 sm:py-32">
  <div class="relative mx-auto max-w-2xl overflow-hidden rounded-2xl border border-border bg-bg-card p-10 text-center sm:p-14">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_70%_60%_at_50%_0%,_rgba(185,28,60,0.13)_0%,_transparent_70%)]"
    >
    </div>
    <div class="relative">
      <div
        class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-bg/60 px-4 py-1.5 text-sm text-text-muted"
      >
        <span class="inline-block h-2 w-2 rounded-full bg-warning"></span>
        Waitlist opening soon
      </div>

      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Earn more on your TRX</h2>
      <p class="mx-auto mt-4 max-w-md text-text-muted">
        We're putting the finishing touches on onboarding. The waitlist opens shortly — check
        back soon.
      </p>

      <!-- Waitlist form — intentionally disabled until signups open. TODO: enable + wire `action`
           to a real handler (Formspree / api.troniti.com) when ready. -->
      <form class="mx-auto mt-8 flex max-w-md flex-col gap-3 sm:flex-row" aria-disabled="true">
        <input
          type="email"
          name="email"
          placeholder="you@email.com"
          disabled
          class="w-full cursor-not-allowed rounded-lg border border-border bg-bg px-4 py-3 text-text placeholder:text-text-muted/40 opacity-60"
        />
        <button
          type="button"
          disabled
          class="shrink-0 cursor-not-allowed rounded-lg bg-accent/50 px-6 py-3 font-medium text-white/70"
        >
          Coming soon
        </button>
      </form>
      <p class="mt-4 text-xs text-text-muted">Non-custodial · you keep custody, always.</p>
    </div>
  </div>
</section>
