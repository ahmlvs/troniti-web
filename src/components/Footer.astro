---
import Logo from "./Logo.astro";

const year = new Date().getFullYear();
const proofTx = "5091276e7f6da12426c92dbde2573998fbafec9d28297f434103b333172a9d26";
---

<footer class="border-t border-border px-6 py-14">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-6 text-center">
    <Logo size="sm" />

    <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-text-muted">
      <a href="#how" class="transition-colors hover:text-text">How it works</a>
      <a href="#trust" class="transition-colors hover:text-text">Trust model</a>
      <a href="#faq" class="transition-colors hover:text-text">FAQ</a>
      <a
        href={`https://tronscan.org/#/transaction/${proofTx}`}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-text">On-chain proof</a
      >
      <a
        href="https://x.com/ahmlvs"
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-text">@ahmlvs</a
      >
    </nav>

    <nav class="flex gap-6 text-sm text-text-muted">
      <a href="/privacy" class="transition-colors hover:text-text">Privacy Policy</a>
      <a href="/terms" class="transition-colors hover:text-text">Terms of Service</a>
    </nav>

    <p class="text-sm text-text-muted">
      &copy; {year} troniti. Non-custodial TRON yield management.
    </p>
  </div>
</footer>
