---
import Logo from "./Logo.astro";

const year = new Date().getFullYear();
const proofTx = "5091276e7f6da12426c92dbde2573998fbafec9d28297f434103b333172a9d26";
---

<footer class="border-t border-border px-6 py-14">
  <div class="mx-auto flex max-w-5xl flex-col items-center gap-6 text-center">
    <Logo size="sm" />

    <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm text-text-muted">
      <a href="#how" class="transition-colors hover:text-text">How it works</a>
      <a href="#trust" class="transition-colors hover:text-text">Trust model</a>
      <a href="#faq" class="transition-colors hover:text-text">FAQ</a>
      <a
        href={`https://tronscan.org/#/transaction/${proofTx}`}
        target="_blank"
        rel="noopener noreferrer"
        class="transition-colors hover:text-text">On-chain proof</a
      >
    </nav>

    <nav class="flex items-center gap-5">
      <a
        href="https://github.com/ahmlvs/troniti-web"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="troniti on GitHub"
        class="text-text-muted transition-colors hover:text-text"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
          <path d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.05-3.34.73-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49.99.11-.78.42-1.3.76-1.6-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 3-.4c1.02 0 2.05.14 3 .4 2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.62-5.48 5.92.43.37.81 1.1.81 2.22 0 1.61-.01 2.9-.01 3.29 0 .32.21.7.82.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5z" />
        </svg>
      </a>
      <a
        href="https://x.com/ahmlvs"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="troniti on X"
        class="text-text-muted transition-colors hover:text-text"
      >
        <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.657l-5.214-6.817-5.966 6.817H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
        </svg>
      </a>
    </nav>

    <nav class="flex gap-6 text-sm text-text-muted">
      <a href="/privacy" class="transition-colors hover:text-text">Privacy Policy</a>
      <a href="/terms" class="transition-colors hover:text-text">Terms of Service</a>
    </nav>

    <p class="text-sm text-text-muted">
      &copy; {year} troniti. Non-custodial TRON yield management.
    </p>
  </div>
</footer>
