---
const faqs = [
  {
    q: "Is this custodial?",
    a: "No. You keep your keys; we hold a restricted on-chain permission, not your funds.",
  },
  {
    q: "Can troniti move or unstake my TRX?",
    a: "No — the permission has no Transfer or Unfreeze rights. It can only stake, vote, claim, and delegate/undelegate energy. Verify it on-chain.",
  },
  {
    q: "How do I stop?",
    a: "Remove the permission in any TRON wallet, anytime. No notice, no lockup.",
  },
  {
    q: "Which chain?",
    a: "TRON (Stake 2.0).",
  },
  {
    q: "Is there a minimum?",
    a: "To be set when onboarding opens — join the waitlist and we'll let you know.",
  },
];
---

<section id="faq" class="border-t border-border px-6 py-20 sm:py-24">
  <div class="mx-auto max-w-3xl">
    <h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">Frequently asked</h2>

    <div class="mt-12 divide-y divide-border rounded-xl border border-border bg-bg-card">
      {
        faqs.map((f) => (
          <details class="group px-6 py-5">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-medium">
              {f.q}
              <svg
                class="h-5 w-5 shrink-0 text-text-muted transition-transform group-open:rotate-45"
                viewBox="0 0 20 20"
                fill="currentColor"
              >
                <path d="M10 4a1 1 0 0 1 1 1v4h4a1 1 0 1 1 0 2h-4v4a1 1 0 1 1-2 0v-4H5a1 1 0 1 1 0-2h4V5a1 1 0 0 1 1-1Z" />
              </svg>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-text-muted">{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
