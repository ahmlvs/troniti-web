---
const steps = [
  {
    n: "1",
    title: "Stake your TRX",
    body: "You stake in your own wallet. Nothing is ever sent to us — your principal never leaves your account.",
  },
  {
    n: "2",
    title: "Grant a restricted permission",
    body: "A 5-action operator permission: stake, vote, claim, and rent energy. No transfers, no unstaking, no account changes.",
  },
  {
    n: "3",
    title: "We maximize your yield",
    body: "Continuous claim → restake → re-vote, plus renting out your idle energy. All rewards and rental income land in your wallet.",
  },
];
---

<section id="how" class="border-t border-border px-6 py-20 sm:py-24">
  <div class="mx-auto max-w-5xl">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">How it works</h2>
      <p class="mt-4 text-lg text-text-muted">Three steps. You stay in custody the whole time.</p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {
        steps.map((s) => (
          <div class="rounded-xl border border-border bg-bg-card p-6">
            <span class="mono flex h-9 w-9 items-center justify-center rounded-lg border border-border text-accent">
              {s.n}
            </span>
            <h3 class="mt-5 text-lg font-semibold">{s.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">{s.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
